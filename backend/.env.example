# =============================================================================
# Otoki PowerSales Backend — 환경변수 예시
# =============================================================================
# 사용법
#   - 로컬 개발: SPRING_PROFILES_ACTIVE=local 로 띄우면 application-local.yml 이
#     DB / Redis / S3 auto-config 를 모두 exclude 하므로 RDS_*/REDIS_*/RDS_SECRET_ARN
#     등 외부 인프라 env 는 비워둘 수 있다.
#   - dev/prod 배포 (EB): 아래 env 를 EB 콘솔(Configuration → Software) 환경
#     속성에 입력한다. RDS_SECRET_ARN 으로 master password secret 을 가리키면
#     spring.config.import 가 부팅 시 1회 읽어 ${password} placeholder 를
#     바인딩한다.

# === Spring Profile ===
# local | dev | prod
SPRING_PROFILES_ACTIVE=local
# app.stage placeholder. CloudFront/EB stage 식별용 라벨
STAGE=local

# === RDS (PostgreSQL Aurora) — dev/prod 필수, local 무영향 ===
RDS_HOST=
RDS_PORT=5432
RDS_DATABASE=otoki
RDS_USERNAME=
# password 는 RDS 관리형 master password secret 에서 자동 로드됨 — 본 env 는 비움
# RDS_SECRET_ARN 은 dev/prod document 에서 spring.config.import 로 사용
RDS_SECRET_ARN=

# === Redis (ElastiCache Valkey, 클러스터 모드 + TLS) — dev/prod 필수, local 무영향 ===
# REDIS_ENDPOINT 는 구성 엔드포인트(clustercfg.*) 호스트, REDIS_PORT 는 6379
REDIS_ENDPOINT=
REDIS_PORT=6379

# === AWS — Secrets Manager / S3 region ===
AWS_REGION=ap-northeast-2
S3_BUCKET=

# === JWT ===
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# === Optional overrides (defaults exist in application.yml) ===
# HIKARI_MAX_POOL=5
# HIKARI_MIN_IDLE=2
# JPA_SHOW_SQL=true
# SERVER_PORT=8080
# LOG_LEVEL_ROOT=INFO
# LOG_LEVEL_APP=DEBUG
# ORORA_MOCK_ENABLED=true

# === 외부 도메인 (CloudFront 도메인 가드용) ===
# API_DOMAIN=
# ADMIN_DOMAIN=

# === SAP 인바운드 인증 (Spec #555 P1-B) ===
# SAP 측에 발급한 OAuth 클라이언트 ID
SAP_CLIENT_ID=
# client_secret 의 BCrypt 해시 (평문 저장 금지). 발급 시:
#   htpasswd -bnBC 12 "" "<평문>" | tr -d ':\n'
SAP_CLIENT_SECRET_HASH=
# HS256 서명용 비밀키 (최소 256-bit). mobile/admin JWT 키와 분리해서 운용
SAP_JWT_SIGNING_KEY=
# backend 단 IP allowlist (콤마 구분 CIDR). 비워두면 backend 단 검증 비활성
# (ALB 단의 listener rule 만으로 통제). 예: 203.0.113.0/24,198.51.100.10/32
SAP_ALLOWED_IPS=

# === SAP 아웃바운드 공통 (Spec #534) ===
# `sap-integration.md` §11.5 환경변수 재사용 정책 — 도메인별로 신규 정의 금지.
# 모든 SAP 아웃바운드 sender 가 본 env 를 공유. interfaceId 는 코드 상수
# (`SapConstants.SAP_INTERFACE_*`) 로 관리하며 환경변수화 금지 (§11.3)
SAP_OUTBOUND_BASE_URL=
SAP_OUTBOUND_USERNAME=
SAP_OUTBOUND_PASSWORD=
# Optional — 기본값은 application.yml 에서 정의
# SAP_OUTBOUND_CONNECT_TIMEOUT_MS=5000
# SAP_OUTBOUND_READ_TIMEOUT_MS=120000
# SAP_OUTBOUND_RETRY_MAX_ATTEMPTS=3
# SAP_OUTBOUND_RETRY_DELAY_MS=1000

# === SAP 아웃바운드 도메인별 — 출근 / 진열 마스터 (Spec #588 P1/P2) ===
# Daily cron batch 트리거 (레거시 SF Setup UI 등록 cron 동등). 운영팀 협의 후 확정
# P1 — 일반 출근 (REGULAR)
APP_SAP_OUTBOUND_ATTENDANCE_CRON=0 0 1 * * *
APP_SAP_OUTBOUND_ATTENDANCE_PAGE_SIZE=100
# P2 — 진열 마스터 (DISPLAY)
APP_SAP_OUTBOUND_DISPLAY_CRON=0 0 1 * * *
APP_SAP_OUTBOUND_DISPLAY_PAGE_SIZE=100
